---
layout: null
---
[{% for post in site.posts %}{"url":"{{ post.url }}","title":{{ post.title | jsonify }},"date":"{{ post.date | date: "%Y-%m-%d" }}","excerpt":{{ post.excerpt | strip_html | strip_newlines | truncatewords: 30 | jsonify }},"reading_time":{{ post.content | number_of_words | divided_by: 200 | at_least: 1 }},"series":{{ post.series | jsonify }},"part":{{ post.part | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
